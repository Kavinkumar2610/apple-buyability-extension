{
  "manifest_version": 3,
  "name": "Apple MacBook Availability Checker",
  "version": "1.0",
  "description": "Polls Apple store every 30 mins — shows MacBook availability (Air M5, Pro M5 14\", Pro 2024) as a badge on the icon.",
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://www.apple.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/apple-logo.png",
    "default_title": "MacBook Availability Checker"
  },
  "icons": {
    "128": "icons/apple-logo.png"
  }
}